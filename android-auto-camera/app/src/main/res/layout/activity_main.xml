<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📷 小米13 Ultra\n摄影助手"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="进入相机自动显示拍摄指导"
        android:textSize="16sp"
        android:textColor="#666666"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="正在检查服务状态..."
        android:textSize="16sp"
        android:padding="16dp"
        android:background="#F5F5F5"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btn_enable_service"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="开启无障碍服务"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_open_settings"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="开启悬浮窗权限"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        android:visibility="gone"/>

    <Button
        android:id="@+id/btn_quick_test"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="⚡ 查看快速技巧"
        android:textSize="16sp"
        style="@style/Widget.AppCompat.Button.Borderless.Colored"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="使用说明:\n\n" +
                "1. 开启「无障碍服务」权限\n" +
                "2. 开启「悬浮窗」权限\n" +
                "3. 打开相机APP，自动弹出指导\n" +
                "4. 点击场景按钮查看详细参数\n\n" +
                "支持场景：人像、夜景、街拍、风景、美食、星空"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginTop="32dp"
        android:lineSpacingMultiplier="1.3"/>

</LinearLayout>
